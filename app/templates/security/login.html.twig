{% extends 'base.html.twig' %}

{% block main %}
    <div class="w-full">
        {% if error %}
            <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg mb-4">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {% if app.user %}
            <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg mb-4">
                You are logged in as {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}" class="font-semibold hover:underline">Logout</a>
            </div>
        {% endif %}

        <h1 class="text-2xl font-serif text-moss mb-6">Please sign in</h1>
        
        <form method="post" class="space-y-4">
            <div>
                <label for="username" class="block text-sm font-medium text-moss mb-1.5">Email</label>
                <input type="email" value="{{ last_username }}" name="_username" id="username" class="w-full px-3 py-2 border border-fern rounded-lg bg-cream text-bark placeholder-sage focus:outline-none focus:ring-2 focus:ring-sage focus:border-transparent" autocomplete="email" required autofocus>
            </div>
            
            <div>
                <label for="password" class="block text-sm font-medium text-moss mb-1.5">Password</label>
                <input type="password" name="_password" id="password" class="w-full px-3 py-2 border border-fern rounded-lg bg-cream text-bark placeholder-sage focus:outline-none focus:ring-2 focus:ring-sage focus:border-transparent" autocomplete="current-password" required>
            </div>
            
            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="w-full mt-6 px-4 py-2.5 bg-sage text-cream font-medium rounded-lg hover:bg-moss transition-colors">
                Sign in
            </button>
        </form>
    </div>
{% endblock %}
